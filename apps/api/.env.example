# Copy to .env and fill in your values (do not commit .env):
#   cp .env.example .env

OPENAI_API_KEY=your-openai-key

# Cursor Agent pipeline (optional — workspace chat_mode=cursor_agent)
CURSOR_API_KEY=
CURSOR_AGENT_MODEL=composer-2.5
# PERSONALOPS_CHAT_DEFAULT_MODE=langgraph

DATA_DIR=../../data
DATABASE_URL=sqlite+aiosqlite:///../../data/personalops.db
CHROMA_PERSIST_DIR=../../data/chroma

# Web search (optional)
TAVILY_API_KEY=
WEB_SEARCH_PROVIDER=tavily

# OCR — use Azure (recommended for scanned PDFs)
OCR_PROVIDER=azure
AZURE_VISION_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_VISION_KEY=your-azure-key
OCR_MAX_PAGES=150

# OCR — or local Tesseract (brew install tesseract)
# OCR_PROVIDER=tesseract
# OCR_LANG=eng

# Agent conversation history turns (default 5 = 10 messages)
# AGENT_HISTORY_TURNS=5

# GitHub read-only sync (optional — public repos work without a token)
# GITHUB_TOKEN=

# Code keyword search (optional — falls back to Python scan if rg is missing)
# RIPGREP_BIN=/opt/homebrew/bin/rg

# Folder watcher debounce (seconds)
# WATCHER_DEBOUNCE_SEC=2

# Chat evaluation metrics (default true)
# METRICS_ENABLED=true

# Life workspace — Outlook mail + calendar (Microsoft Graph)
# Register app at https://portal.azure.com → App registrations
# MS_GRAPH_CLIENT_ID=
# MS_GRAPH_CLIENT_SECRET=   # optional for desktop public client (default)
# MS_GRAPH_PUBLIC_CLIENT=true
# MS_GRAPH_TENANT_ID=common
# LIFE_OUTLOOK_POLL_SEC=120

# Life workspace — Google Gmail + Calendar (Phase 2)
# Redirect URI: http://127.0.0.1:8765/oauth/google/callback
# Google often requires client_secret on token exchange even for Desktop app clients.
# Copy Client secret from Google Cloud Console (Credentials → your OAuth client).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_PUBLIC_CLIENT=false

# Agent personalization (P0+)
# PERSONALIZATION_ENABLED=true
# PROMPT_DAILY_THRESHOLD=100
# PROMPT_WEEKLY_THRESHOLD=700
# PROMPT_LOG_RETENTION_DAYS=90
# PROMPT_DISTILL_MODEL=gpt-4o-mini
# AUTO_MEMORY_REQUIRE_APPROVAL=true
# PERSONALIZATION_DISTILL_SCHEDULE=both

# P3 — Cloud archive (encrypted redacted prompt logs)
# CLOUD_ARCHIVE_ENABLED=false
# CLOUD_ARCHIVE_PROVIDER=gcs
# PERSONALIZATION_ARCHIVE_KEY=
# GCS_ARCHIVE_BUCKET=
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcs-archive-sa.json

# Edition: local (desktop default) | cloud (Plan B web — LangGraph only, skips Cursor bridge)
# DEPLOYMENT_MODE=local

# B1 — Auth (required when DEPLOYMENT_MODE=cloud)
# JWT_SECRET=change-me-to-a-long-random-string
# JWT_EXPIRE_HOURS=168

# B1/B2 — Admin bootstrap (claim legacy workspaces + import .env keys)
# DEMO_EMAIL=demo@personalops.live
# DEMO_PASSWORD=demo1234
# DEMO_AUTO_SEED=false
# ADMIN_PASSWORD=change-me-min-8-chars
# CREDENTIALS_ENCRYPTION_KEY=   # Fernet source for user API keys (falls back to JWT_SECRET)
# GCS_APP_BUCKET=personalops-personal
# GCS_STORAGE_ENABLED=true

# Email auth (Resend) — cloud register verify + password reset
# RESEND_API_KEY=re_your_key
# EMAIL_FROM=PersonalOps <noreply@personalops.live>
# AUTH_EMAIL_CODE_TTL_MINUTES=15
# AUTH_EMAIL_RESEND_COOLDOWN_SEC=60

# Cloud Life OAuth callbacks (when DEPLOYMENT_MODE=cloud and API on HTTPS)
# LIFE_OAUTH_MICROSOFT_REDIRECT_URI=https://app.yourdomain.com/oauth/microsoft/callback
# LIFE_OAUTH_GOOGLE_REDIRECT_URI=https://app.yourdomain.com/oauth/google/callback
# S3_ARCHIVE_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# Web search provider: tavily | duckduckgo (falls back to duckduckgo without TAVILY_API_KEY)
# WEB_SEARCH_PROVIDER=tavily
