# Copy to .env before: docker compose up -d --build
#   cp env.example .env

# --- Required ---
POSTGRES_PASSWORD=change-me-strong-postgres-password
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# --- Admin bootstrap (first login) ---
ADMIN_EMAIL=admin@personalops.local
ADMIN_PASSWORD=change-me-min-8-chars
CREDENTIALS_ENCRYPTION_KEY=

# --- GCS (Plan B B3/B4) ---
GCS_STORAGE_ENABLED=true
GCS_APP_BUCKET=personalops-personal
# Path on the VM/host to your service account JSON (mounted into api container)
GCS_SA_FILE=./secrets/gcs-archive-sa.json

# --- Optional OCR (recommended: Azure for scanned PDFs) ---
OCR_PROVIDER=azure
AZURE_VISION_ENDPOINT=
AZURE_VISION_KEY=

# --- Optional Life OAuth (HTTPS production URLs) ---
# LIFE_OAUTH_GOOGLE_REDIRECT_URI=https://app.yourdomain.com/oauth/google/callback
# LIFE_OAUTH_MICROSOFT_REDIRECT_URI=https://app.yourdomain.com/oauth/microsoft/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MS_GRAPH_CLIENT_ID=
# MS_GRAPH_CLIENT_SECRET=

# --- Host port for web (nginx) ---
HTTP_PORT=80

# --- Email auth (Resend) — register verify + forgot password ---
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=PersonalOps <noreply@personalops.live>
# AUTH_EMAIL_CODE_TTL_MINUTES=15
# AUTH_EMAIL_RESEND_COOLDOWN_SEC=60
